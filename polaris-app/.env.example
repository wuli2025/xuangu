# 复制为 .env 后填写；docker compose 会自动读取。
# ── 接入 LLM（三选一）──
# A. Claude 官方 API Key
ANTHROPIC_API_KEY=

# B. 第三方 Anthropic 兼容端点（智谱/Kimi/DeepSeek/聚合站等）
#    填 BASE_URL + AUTH_TOKEN，留空 ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# ── 访问口令（公网部署强烈建议设置；浏览器用 http://host:8080/?token=xxx 访问）──
POLARIS_AUTH_TOKEN=
